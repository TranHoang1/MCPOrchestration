<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="Sequence: Config-DB Sync on Startup (UC-06)" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="120" y="10" width="450" height="30" as="geometry"/>
    </mxCell>
    <!-- Lifelines -->
    <mxCell id="a1" value="Application&#xa;(Startup)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;participant=umlEntity;size=16;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="40" y="60" width="100" height="520" as="geometry"/>
    </mxCell>
    <mxCell id="a2" value="ConfigDbSync&#xa;Service" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;participant=umlEntity;size=16;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
      <mxGeometry x="220" y="60" width="120" height="520" as="geometry"/>
    </mxCell>
    <mxCell id="a3" value="Config File&#xa;(mcp-servers.json)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;participant=umlEntity;size=16;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="420" y="60" width="120" height="520" as="geometry"/>
    </mxCell>
    <mxCell id="a4" value="PostgreSQL" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;participant=umlEntity;size=16;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
      <mxGeometry x="620" y="60" width="100" height="520" as="geometry"/>
    </mxCell>
    <!-- Messages -->
    <mxCell id="m1" value="syncConfigToDb()" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="90" y="150" as="sourcePoint"/>
        <mxPoint x="280" y="150" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="1. Read &amp; parse mcp-servers.json" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="280" y="190" as="sourcePoint"/>
        <mxPoint x="480" y="190" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m3" value="Server configs" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="480" y="220" as="sourcePoint"/>
        <mxPoint x="280" y="220" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m4" value="2. SELECT * FROM server_config" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="280" y="260" as="sourcePoint"/>
        <mxPoint x="670" y="260" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="Existing records" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="670" y="290" as="sourcePoint"/>
        <mxPoint x="280" y="290" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m6" value="3. Compute diff (add/update/deactivate)" style="html=1;verticalAlign=bottom;endArrow=block;dashed=1;strokeColor=#999999;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="280" y="320" as="sourcePoint"/>
        <mxPoint x="280" y="340" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m7" value="4. INSERT new / UPDATE changed / SET is_active=false" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="280" y="370" as="sourcePoint"/>
        <mxPoint x="670" y="370" as="targetPoint"/>
      </mxGeometry>
