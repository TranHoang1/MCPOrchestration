    </mxCell>
    <mxCell id="n9" value="Load 3d-force-graph&#xa;Library (CDN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;" vertex="1" parent="lane2">
      <mxGeometry x="120" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
