      <mxGeometry x="16" y="64" width="1168" height="720" as="geometry"/>
    </mxCell>
    <!-- Simulated 3D graph nodes -->
    <mxCell id="node-epic" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#9C27B0;strokeColor=none;aspect=fixed;" vertex="1" parent="1">
      <mxGeometry x="500" y="300" width="40" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="node-story1" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#4CAF50;strokeColor=none;aspect=fixed;" vertex="1" parent="1">
