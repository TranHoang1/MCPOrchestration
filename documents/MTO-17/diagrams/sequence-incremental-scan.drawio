<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Sequence — Incremental Scan&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="200" y="10" width="300" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="sch" value="Scheduler" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="60" y="50" width="100" height="420" as="geometry"/>
    </mxCell>
    <mxCell id="ps" value="ProjectScanner" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="230" y="50" width="120" height="420" as="geometry"/>
    </mxCell>
    <mxCell id="sm" value="SyncState&#xa;Manager" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="420" y="50" width="100" height="420" as="geometry"/>
    </mxCell>
    <mxCell id="jc" value="JiraRest&#xa;Client" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="590" y="50" width="100" height="420" as="geometry"/>
    </mxCell>
    <mxCell id="db" value="PostgreSQL" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="760" y="50" width="100" height="420" as="geometry"/>
    </mxCell>
    <mxCell id="m1" value="scan(projectKey)" style="html=1;endSize=6;startSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="110" y="120" as="sourcePoint"/>
        <mxPoint x="290" y="120" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="getState(projectKey)" style="html=1;endSize=6;startSize=6;fontSize=10;" edge="1" parent="1">
