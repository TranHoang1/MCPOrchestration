<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="&lt;b&gt;State Machine — Sync Status Lifecycle (MTO-15)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="150" y="10" width="450" height="30" as="geometry"/>
    </mxCell>
    <!-- Start -->
    <mxCell id="start" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="365" y="60" width="30" height="30" as="geometry"/>
    </mxCell>
    <!-- States -->
    <mxCell id="idle" value="&lt;b&gt;IDLE&lt;/b&gt;&lt;br&gt;(Initial state)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="310" y="130" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="running" value="&lt;b&gt;RUNNING&lt;/b&gt;&lt;br&gt;(Sync in progress)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="310" y="260" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="completed" value="&lt;b&gt;COMPLETED&lt;/b&gt;&lt;br&gt;(Sync finished)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="60" y="400" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="failed" value="&lt;b&gt;FAILED&lt;/b&gt;&lt;br&gt;(Error occurred)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="310" y="400" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="paused" value="&lt;b&gt;PAUSED&lt;/b&gt;&lt;br&gt;(Interrupted)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="560" y="400" width="140" height="60" as="geometry"/>
    </mxCell>
    <!-- Transitions -->
    <mxCell id="e_start" value="getOrCreate()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="start" target="idle" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_idle_run" value="markRunning()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="idle" target="running" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_run_comp" value="markCompleted()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="running" target="completed" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_run_fail" value="markFailed(error)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="running" target="failed" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_run_pause" value="markPaused()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="running" target="paused" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_pause_run" value="markRunning()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" edge="1" source="paused" target="running" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="630" y="350"/>
          <mxPoint x="500" y="350"/>
          <mxPoint x="500" y="290"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e_fail_run" value="markRunning() (retry)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" edge="1" source="failed" target="running" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="380" y="370"/>
          <mxPoint x="450" y="370"/>
          <mxPoint x="450" y="290"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e_comp_run" value="markRunning() (re-sync)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" edge="1" source="completed" target="running" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="130" y="350"/>
          <mxPoint x="260" y="350"/>
          <mxPoint x="260" y="290"/>
        </Array>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
