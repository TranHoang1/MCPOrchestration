<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="sys" value="&lt;b&gt;Dual-Priority Queue System&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#e1f5fe;strokeColor=#0288d1;html=1;" vertex="1" parent="1">
      <mxGeometry x="200" y="20" width="500" height="560" as="geometry"/>
    </mxCell>
    <mxCell id="uc1" value="Enqueue High-Priority Task" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;" vertex="1" parent="sys">
      <mxGeometry x="40" y="50" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc2" value="Enqueue Normal-Priority Task" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;" vertex="1" parent="sys">
      <mxGeometry x="40" y="130" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc3" value="Process Task&#xa;(Worker)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;" vertex="1" parent="sys">
      <mxGeometry x="280" y="90" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc4" value="Preempt NPQ Task" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="sys">
      <mxGeometry x="280" y="180" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc5" value="Re-queue Preempted Task" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;" vertex="1" parent="sys">
      <mxGeometry x="280" y="270" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc6" value="Track Task State&#xa;(PostgreSQL)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;" vertex="1" parent="sys">
      <mxGeometry x="40" y="270" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc7" value="Detect Stuck Tasks&#xa;(Watchdog)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="sys">
      <mxGeometry x="40" y="360" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc8" value="Retry Failed Task&#xa;(Exponential Backoff)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;" vertex="1" parent="sys">
      <mxGeometry x="280" y="360" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc9" value="Recover from Crash" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="sys">
      <mxGeometry x="160" y="460" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="actor1" value="User/UI" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;" vertex="1" parent="1">
      <mxGeometry x="80" y="60" width="40" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="actor2" value="System/Batch" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;" vertex="1" parent="1">
