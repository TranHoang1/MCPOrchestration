    </mxCell>
    <mxCell id="lane2" value="Reconnection" style="swimlane;horizontal=0;startSize=110;fillColor=#fff0e6;html=1;" vertex="1" parent="1">
      <mxGeometry x="0" y="150" width="1400" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="n7" value="State:&#xa;DISCONNECTED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="lane2">
      <mxGeometry x="840" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="n8" value="Wait Backoff&#xa;(exp delay)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;" vertex="1" parent="lane2">
      <mxGeometry x="1020" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="n9" value="Attempt&#xa;Reconnect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;" vertex="1" parent="lane2">
