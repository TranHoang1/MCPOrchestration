    </mxCell>
    <mxCell id="m7" value="retry activeUrl (attempt 3)" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="340" y="350" as="sourcePoint"/>
        <mxPoint x="740" y="350" as="targetPoint"/>
