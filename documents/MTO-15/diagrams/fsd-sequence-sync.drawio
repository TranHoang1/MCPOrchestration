      <mxGeometry x="660" y="50" width="120" height="600" as="geometry"/>
    </mxCell>
    <!-- Messages -->
    <mxCell id="m1" value="1. getOrCreate(&quot;MTO&quot;)" style="html=1;endSize=6;startSize=6;fontSize=10;" edge="1" parent="1">
