      <mxGeometry x="444" y="22" width="80" height="28" as="geometry"/>
    </mxCell>
    <!-- WebSocket indicator -->
    <mxCell id="ws-dot" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3fb950;strokeColor=none;aspect=fixed;" vertex="1" parent="1">
      <mxGeometry x="540" y="30" width="10" height="10" as="geometry"/>
    </mxCell>
    <!-- 3D Graph area (center, full viewport) -->
