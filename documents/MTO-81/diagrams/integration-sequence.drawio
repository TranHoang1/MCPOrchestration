<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Integration Sequence — Label Lifecycle&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="200" y="10" width="400" height="30" as="geometry"/>
    </mxCell>
    <!-- Lifelines -->
    <mxCell id="ll1" value="loadGraph()" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="40" y="60" width="100" height="450" as="geometry"/>
    </mxCell>
    <mxCell id="ll2" value="3d-force-graph" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="200" y="60" width="120" height="450" as="geometry"/>
    </mxCell>
    <mxCell id="ll3" value="LabelManager" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="380" y="60" width="120" height="450" as="geometry"/>
    </mxCell>
    <mxCell id="ll4" value="Three.js" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="560" y="60" width="100" height="450" as="geometry"/>
    </mxCell>
    <!-- Messages -->
    <mxCell id="m1" value="1. graphData({nodes, links})" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="90" y="130" as="sourcePoint"/>
        <mxPoint x="260" y="130" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="2. nodeThreeObject(node) [per node]" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="260" y="170" as="sourcePoint"/>
        <mxPoint x="440" y="170" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m3" value="3. createLabel(node)" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="440" y="200" as="sourcePoint"/>
        <mxPoint x="610" y="200" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m4" value="4. new Sprite(material)" style="html=1;endSize=6;dashed=1;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="610" y="230" as="sourcePoint"/>
        <mxPoint x="440" y="230" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="5. return sprite" style="html=1;endSize=6;dashed=1;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="440" y="260" as="sourcePoint"/>
        <mxPoint x="260" y="260" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m6" value="6. onEngineTick [per frame]" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="260" y="320" as="sourcePoint"/>
        <mxPoint x="440" y="320" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m7" value="7. updateVisibility(camera)" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="440" y="350" as="sourcePoint"/>
        <mxPoint x="610" y="350" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m8" value="8. sprite.material.opacity = x" style="html=1;endSize=6;dashed=1;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="610" y="380" as="sourcePoint"/>
        <mxPoint x="440" y="380" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <!-- Phase labels -->
    <mxCell id="phase1" value="INIT PHASE" style="text;html=1;align=left;fontSize=9;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
      <mxGeometry x="650" y="120" width="80" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="phase2" value="RENDER LOOP" style="text;html=1;align=left;fontSize=9;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
      <mxGeometry x="650" y="310" width="80" height="20" as="geometry"/>
    </mxCell>
    <!-- Separator -->
    <mxCell id="sep" value="" style="html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="30" y="290" as="sourcePoint"/>
        <mxPoint x="730" y="290" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
