<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;State Diagram — Indexing Engine&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="200" y="10" width="350" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="start" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="60" y="80" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="idle" value="IDLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="160" y="70" width="120" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="scanning" value="SCANNING&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Traversing files&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="380" y="70" width="140" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="indexing" value="INDEXING&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Extracting + storing&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="600" y="70" width="150" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="embedding" value="EMBEDDING&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Generating vectors&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=12;fontStyle=1;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="600" y="220" width="150" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="summarizing" value="SUMMARIZING&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;AI summaries&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=12;fontStyle=1;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="380" y="220" width="150" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="ready" value="READY&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;All layers active&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="160" y="220" width="140" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="error" value="ERROR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="160" y="360" width="120" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="e_start_idle" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="start" target="idle" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_idle_scan" value="startup / file change" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="idle" target="scanning" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_scan_idx" value="files found" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="scanning" target="indexing" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_idx_emb" value="Layer 2 active" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;dashed=1;" edge="1" source="indexing" target="embedding" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_emb_sum" value="Layer 3 active" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;dashed=1;" edge="1" source="embedding" target="summarizing" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_sum_ready" value="complete" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="summarizing" target="ready" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_idx_ready" value="Layer 2 inactive" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="indexing" target="ready" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_ready_idle" value="file change" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="ready" target="idle" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_any_error" value="fatal error" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;strokeColor=#c62828;" edge="1" source="scanning" target="error" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_error_idle" value="retry / reset" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="error" target="idle" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
