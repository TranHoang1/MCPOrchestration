    </mxCell>
    <mxCell id="err_parse" value="HTTP 400&lt;br&gt;Parse Error (-32700)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=10;" vertex="1" parent="1">
