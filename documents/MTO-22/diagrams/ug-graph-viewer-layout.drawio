    <mxCell id="search_box" value="🔍 Search tickets..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
