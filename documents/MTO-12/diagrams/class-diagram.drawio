    <!-- FileProxyService Interface -->
    <mxCell id="fps_if" value="&lt;b&gt;«interface»&lt;br&gt;FileProxyService&lt;/b&gt;&lt;hr&gt;+initialize(sessionId: UUID)&lt;br&gt;+handleProxyCall(...): ExecuteToolResponse&lt;br&gt;+isProxyTool(toolName): Boolean&lt;br&gt;+redetectServer(serverName)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
