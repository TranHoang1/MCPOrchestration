<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Page background (dark) -->
    <mxCell id="bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#30363d;" vertex="1" parent="1">
      <mxGeometry x="0" y="0" width="1200" height="600" as="geometry"/>
    </mxCell>
    <!-- Controls bar with depth selector and back button -->
    <mxCell id="controls" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;" vertex="1" parent="1">
      <mxGeometry x="16" y="16" width="800" height="40" as="geometry"/>
    </mxCell>
    <!-- Project input -->
    <mxCell id="project-input" value="&lt;font color=&quot;#c9d1d9&quot;&gt;MTO&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="24" y="22" width="80" height="28" as="geometry"/>
    </mxCell>
    <!-- View mode select -->
    <mxCell id="view-select" value="&lt;font color=&quot;#c9d1d9&quot;&gt;Hierarchy ▾&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="114" y="22" width="130" height="28" as="geometry"/>
    </mxCell>
    <!-- Search input -->
    <mxCell id="search-input" value="&lt;font color=&quot;#8b949e&quot;&gt;Search...&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="254" y="22" width="140" height="28" as="geometry"/>
    </mxCell>
    <!-- Depth selector -->
    <mxCell id="depth-select" value="&lt;font color=&quot;#c9d1d9&quot;&gt;Depth: 2 ▾&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="404" y="22" width="100" height="28" as="geometry"/>
    </mxCell>
    <!-- Back to full graph button -->
    <mxCell id="btn-back" value="&lt;font color=&quot;#58a6ff&quot;&gt;← Full Graph&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#58a6ff;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="520" y="22" width="110" height="28" as="geometry"/>
    </mxCell>
    <!-- Subgraph visualization -->
    <mxCell id="graph-area" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#30363d;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="16" y="64" width="1168" height="520" as="geometry"/>
    </mxCell>
    <!-- Center node (1.5x size, highlighted) -->
    <mxCell id="center-node" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#4CAF50;strokeColor=#58a6ff;strokeWidth=3;aspect=fixed;" vertex="1" parent="1">
      <mxGeometry x="540" y="260" width="50" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="center-label" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:10px&quot;&gt;MTO-22&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="535" y="314" width="60" height="16" as="geometry"/>
    </mxCell>
    <!-- 1-hop neighbors -->
    <mxCell id="hop1-a" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#9C27B0;strokeColor=none;aspect=fixed;" vertex="1" parent="1">
      <mxGeometry x="540" y="120" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="hop1-a-label" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:9px&quot;&gt;MTO-14&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="530" y="152" width="50" height="14" as="geometry"/>
    </mxCell>
    <mxCell id="hop1-b" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#2196F3;strokeColor=none;aspect=fixed;" vertex="1" parent="1">
      <mxGeometry x="360" y="300" width="24" height="24" as="geometry"/>
    </mxCell>
    <mxCell id="hop1-b-label" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:9px&quot;&gt;MTO-23&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="347" y="326" width="50" height="14" as="geometry"/>
    </mxCell>
    <mxCell id="hop1-c" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#2196F3;strokeColor=none;aspect=fixed;" vertex="1" parent="1">
      <mxGeometry x="740" y="240" width="24" height="24" as="geometry"/>
    </mxCell>
    <mxCell id="hop1-c-label" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:9px&quot;&gt;MTO-24&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="727" y="266" width="50" height="14" as="geometry"/>
    </mxCell>
    <!-- 2-hop neighbors -->
    <mxCell id="hop2-a" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#4CAF50;strokeColor=none;aspect=fixed;opacity=60;" vertex="1" parent="1">
      <mxGeometry x="420" y="120" width="20" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="hop2-b" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#4CAF50;strokeColor=none;aspect=fixed;opacity=60;" vertex="1" parent="1">
      <mxGeometry x="660" y="120" width="20" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="hop2-c" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#F44336;strokeColor=none;aspect=fixed;opacity=60;" vertex="1" parent="1">
      <mxGeometry x="860" y="300" width="20" height="20" as="geometry"/>
    </mxCell>
    <!-- Edges -->
    <mxCell id="e1" style="html=1;strokeColor=#999999;endArrow=classic;endSize=4;" edge="1" source="hop1-a" target="center-node" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e2" style="html=1;strokeColor=#999999;endArrow=classic;endSize=3;" edge="1" source="center-node" target="hop1-b" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e3" style="html=1;strokeColor=#999999;endArrow=classic;endSize=3;" edge="1" source="center-node" target="hop1-c" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e4" style="html=1;strokeColor=#999999;endArrow=classic;endSize=3;opacity=60;" edge="1" source="hop1-a" target="hop2-a" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e5" style="html=1;strokeColor=#999999;endArrow=classic;endSize=3;opacity=60;" edge="1" source="hop1-a" target="hop2-b" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e6" style="html=1;strokeColor=#f44336;endArrow=classic;endSize=4;strokeWidth=2;opacity=60;" edge="1" source="hop1-c" target="hop2-c" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Stats bar (bottom-right) -->
    <mxCell id="stats" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;" vertex="1" parent="1">
      <mxGeometry x="1000" y="520" width="180" height="56" as="geometry"/>
    </mxCell>
    <mxCell id="stats-text" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:10px&quot;&gt;Center: MTO-22&lt;br&gt;Depth: 2 hops | Nodes: 6&lt;br&gt;View: hierarchy&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="1012" y="524" width="160" height="48" as="geometry"/>
    </mxCell>
    <!-- Annotation: center node glow -->
    <mxCell id="ann-center" value="&lt;font color=&quot;#58a6ff&quot; style=&quot;font-size:9px&quot;&gt;Center node: 1.5× size&lt;br&gt;+ accent border glow&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="540" y="380" width="140" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="ann-center-edge" style="html=1;dashed=1;strokeColor=#58a6ff;endArrow=classic;endSize=4;" edge="1" source="ann-center" target="center-node" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>