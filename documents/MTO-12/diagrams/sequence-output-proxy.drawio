<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Sequence: Output File Proxy&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="200" y="10" width="400" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="agent_h" value="&lt;b&gt;AI Agent&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;" vertex="1" parent="1">
      <mxGeometry x="60" y="60" width="120" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="agent_l" value="" style="shape=umlLifeline;perimeter=lifelinePerimeter;size=16;html=1;" vertex="1" parent="1">
      <mxGeometry x="115" y="100" width="10" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="proxy_h" value="&lt;b&gt;FileProxyService&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;" vertex="1" parent="1">
      <mxGeometry x="280" y="60" width="140" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="proxy_l" value="" style="shape=umlLifeline;perimeter=lifelinePerimeter;size=16;html=1;" vertex="1" parent="1">
      <mxGeometry x="345" y="100" width="10" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="up_h" value="&lt;b&gt;Upstream Tool&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;" vertex="1" parent="1">
      <mxGeometry x="500" y="60" width="120" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="up_l" value="" style="shape=umlLifeline;perimeter=lifelinePerimeter;size=16;html=1;" vertex="1" parent="1">
      <mxGeometry x="555" y="100" width="10" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="fs_h" value="&lt;b&gt;File System&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;" vertex="1" parent="1">
      <mxGeometry x="700" y="60" width="120" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="fs_l" value="" style="shape=umlLifeline;perimeter=lifelinePerimeter;size=16;html=1;" vertex="1" parent="1">
      <mxGeometry x="755" y="100" width="10" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="m1" value="export_report(report_id, output_path)" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="120" y="160" as="sourcePoint"/>
        <mxPoint x="350" y="160" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="strip output_path, forward" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="350" y="210" as="sourcePoint"/>
        <mxPoint x="560" y="210" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2r" value="{artifacts: [{path: /tmp/report.pdf}]}" style="html=1;endSize=6;startSize=6;dashed=1;fontSize=9;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="560" y="260" as="sourcePoint"/>
        <mxPoint x="350" y="260" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m3" value="detect file content in response" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="350" y="310" as="sourcePoint"/>
        <mxPoint x="350" y="340" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="400" y="310"/>
          <mxPoint x="400" y="340"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m4" value="copy file to output_path" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="350" y="380" as="sourcePoint"/>
        <mxPoint x="760" y="380" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m4r" value="OK (bytes_written)" style="html=1;endSize=6;startSize=6;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="760" y="420" as="sourcePoint"/>
        <mxPoint x="350" y="420" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="{saved_to, bytes_written, source_type}" style="html=1;endSize=6;startSize=6;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="350" y="480" as="sourcePoint"/>
        <mxPoint x="120" y="480" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
