    </mxCell>
    <mxCell id="actor3" value="Watchdog" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;" vertex="1" parent="1">
      <mxGeometry x="80" y="380" width="40" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="actor4" value="Worker" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;" vertex="1" parent="1">
      <mxGeometry x="780" y="120" width="40" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="ea1" style="html=1;endArrow=none;" edge="1" source="actor1" target="uc1" parent="1">
