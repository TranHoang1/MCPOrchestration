      <mxGeometry x="820" y="210" width="100" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="card-last-value" value="&lt;font color=&quot;#eaeaea&quot; style=&quot;font-size:20px&quot;&gt;&lt;b&gt;10:15 AM&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="820" y="240" width="160" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="card-last-sub" value="&lt;font color=&quot;#8892b0&quot; style=&quot;font-size:10px&quot;&gt;Last completed sync&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=bottom;" vertex="1" parent="1">
      <mxGeometry x="820" y="275" width="140" height="15" as="geometry"/>
    </mxCell>
    <!-- Queue Status Badges -->
    <mxCell id="badge-pending" value="&lt;font color=&quot;#ffffff&quot;&gt;Pending: 12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565c0;strokeColor=none;arcSize=50;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="330" width="110" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="badge-processing" value="&lt;font color=&quot;#ffffff&quot;&gt;Processing: 3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57c00;strokeColor=none;arcSize=50;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="165" y="330" width="120" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="badge-completed" value="&lt;font color=&quot;#ffffff&quot;&gt;Completed: 45&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e7d32;strokeColor=none;arcSize=50;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="300" y="330" width="130" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="badge-failed" value="&lt;font color=&quot;#ffffff&quot;&gt;Failed: 2&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c62828;strokeColor=none;arcSize=50;fontSize=11;fontStyle=1;" vertex="1" parent="1">
