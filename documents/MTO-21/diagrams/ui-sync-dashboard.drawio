    <mxCell id="card-synced-value" value="&lt;font color=&quot;#eaeaea&quot; style=&quot;font-size:20px&quot;&gt;&lt;b&gt;45&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="440" y="240" width="80" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="card-synced-sub" value="&lt;font color=&quot;#8892b0&quot; style=&quot;font-size:10px&quot;&gt;of 67 total&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=bottom;" vertex="1" parent="1">
      <mxGeometry x="440" y="275" width="80" height="15" as="geometry"/>
