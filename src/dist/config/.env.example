# ─────────────────────────────────────────────────────────────
# MCP Orchestration — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values for your environment.
# The start scripts will load .env automatically.
# ─────────────────────────────────────────────────────────────

# === Database (shared by orchestrator + kb-server) ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jira_assistant
DB_SCHEMA=public
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}

# === Embedding (Ollama) ===
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_DIMENSIONS=768
EMBEDDING_API_KEY=unused

# === Orchestrator Server ===
ORCHESTRATOR_PORT=9180
ORCHESTRATOR_TRANSPORT=http-streamable

# === KB Server ===
KB_SERVER_PORT=9181
KB_SERVER_TRANSPORT=stdio

# === Security (KB Server) ===
KB_ENCRYPTION_KEY=sMARARO7oHOnD6W2bCPYNSk2F552azl2d1dyVHLG6+w=
KB_BR_ENCRYPTION_KEY=sMARARO7oHOnD6W2bCPYNSk2F552azl2d1dyVHLG6+w=

# === Vector DB ===
VECTOR_DB_PROVIDER=pgvector
VECTOR_DB_COLLECTION=kb_entries

# === Segmentation (KB Server) ===
SEGMENTATION_PROVIDER=ollama
SEGMENTATION_MODEL=llama3
