<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Sequence: Enqueue &amp;amp; Process Task&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="200" y="10" width="300" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="ll1" value="Caller" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;size=40;fillColor=#e1f5fe;strokeColor=#0288d1;" vertex="1" parent="1">
      <mxGeometry x="80" y="50" width="80" height="450" as="geometry"/>
    </mxCell>
    <mxCell id="ll2" value="QueueService" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;size=40;fillColor=#e8f5e9;strokeColor=#388e3c;" vertex="1" parent="1">
      <mxGeometry x="240" y="50" width="100" height="450" as="geometry"/>
    </mxCell>
    <mxCell id="ll3" value="TaskState&#xa;Repository" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;size=40;fillColor=#f3e5f5;strokeColor=#7b1fa2;" vertex="1" parent="1">
      <mxGeometry x="420" y="50" width="100" height="450" as="geometry"/>
    </mxCell>
    <mxCell id="ll4" value="DualPriority&#xa;Queue" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;size=40;fillColor=#fff3e0;strokeColor=#f57c00;" vertex="1" parent="1">
      <mxGeometry x="600" y="50" width="100" height="450" as="geometry"/>
    </mxCell>
    <mxCell id="ll5" value="QueueWorker" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;size=40;fillColor=#e8f5e9;strokeColor=#388e3c;" vertex="1" parent="1">
      <mxGeometry x="780" y="50" width="100" height="450" as="geometry"/>
    </mxCell>
    <mxCell id="m1" value="enqueue(task, HIGH)" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="120" y="120" as="sourcePoint"/>
        <mxPoint x="290" y="120" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="INSERT queue_tasks" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="290" y="150" as="sourcePoint"/>
        <mxPoint x="470" y="150" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m3" value="OK (task_id)" style="html=1;endSize=6;startSize=6;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="470" y="180" as="sourcePoint"/>
        <mxPoint x="290" y="180" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m4" value="send(task) → HPQ" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="290" y="210" as="sourcePoint"/>
        <mxPoint x="650" y="210" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="task_id" style="html=1;endSize=6;startSize=6;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="290" y="240" as="sourcePoint"/>
        <mxPoint x="120" y="240" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m6" value="select {} → receive HPQ" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="830" y="280" as="sourcePoint"/>
        <mxPoint x="650" y="280" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m7" value="task" style="html=1;endSize=6;startSize=6;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="650" y="310" as="sourcePoint"/>
        <mxPoint x="830" y="310" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m8" value="UPDATE status=Processing" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="830" y="340" as="sourcePoint"/>
        <mxPoint x="470" y="340" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m9" value="process(task)" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="830" y="380" as="sourcePoint"/>
        <mxPoint x="830" y="410" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="880" y="395"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m10" value="UPDATE status=Completed" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="830" y="440" as="sourcePoint"/>
        <mxPoint x="470" y="440" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>