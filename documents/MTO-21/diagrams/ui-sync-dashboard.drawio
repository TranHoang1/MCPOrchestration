    <mxCell id="log3" value="&lt;font color=&quot;#e94560&quot;&gt;10:15:20&lt;/font&gt;&lt;font color=&quot;#8892b0&quot;&gt; [attachment_processed] MTO-15 — screenshot.png&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1">
