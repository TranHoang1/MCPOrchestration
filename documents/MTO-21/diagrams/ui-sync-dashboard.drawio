    </mxCell>
    <mxCell id="log4" value="&lt;font color=&quot;#e94560&quot;&gt;10:15:15&lt;/font&gt;&lt;font color=&quot;#8892b0&quot;&gt; [progress] MTO — 42/67 issues (62.7%)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1">
