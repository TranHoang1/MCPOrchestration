<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Sequence Diagram — Background Indexing (File Change)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="150" y="10" width="500" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="fs_h" value="&lt;b&gt;File System&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=30;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
      <mxGeometry x="40" y="60" width="100" height="480" as="geometry"/>
    </mxCell>
    <mxCell id="watcher_h" value="&lt;b&gt;File Watcher&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=30;fillColor=#e1f5fe;strokeColor=#0288d1;" vertex="1" parent="1">
      <mxGeometry x="200" y="60" width="110" height="480" as="geometry"/>
    </mxCell>
    <mxCell id="debounce_h" value="&lt;b&gt;Debounce&lt;/b&gt;&lt;br&gt;Buffer" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=30;fillColor=#fff3e0;strokeColor=#f57c00;" vertex="1" parent="1">
      <mxGeometry x="370" y="60" width="100" height="480" as="geometry"/>
    </mxCell>
    <mxCell id="engine_h" value="&lt;b&gt;Indexing&lt;/b&gt;&lt;br&gt;Engine" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=30;fillColor=#e8f5e9;strokeColor=#388e3c;" vertex="1" parent="1">
      <mxGeometry x="530" y="60" width="100" height="480" as="geometry"/>
    </mxCell>
    <mxCell id="db_h" value="&lt;b&gt;SQLite&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=30;fillColor=#f3e5f5;strokeColor=#7b1fa2;" vertex="1" parent="1">
      <mxGeometry x="690" y="60" width="100" height="480" as="geometry"/>
    </mxCell>
    <mxCell id="m1" value="file modified event" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="90" y="120" as="sourcePoint"/>
        <mxPoint x="255" y="120" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="buffer event" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="255" y="150" as="sourcePoint"/>
        <mxPoint x="420" y="150" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2b" value="another event (same file)" style="html=1;endSize=6;startSize=6;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="90" y="180" as="sourcePoint"/>
        <mxPoint x="255" y="180" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2c" value="merge (reset timer)" style="html=1;endSize=6;startSize=6;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="255" y="200" as="sourcePoint"/>
        <mxPoint x="420" y="200" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="note_debounce" value="&lt;font style=&quot;font-size:9px&quot;&gt;2s quiet period&lt;br&gt;(debounce)&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#fffde7;strokeColor=#f9a825;" vertex="1" parent="1">
      <mxGeometry x="370" y="220" width="100" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="m3" value="emit batched events" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="420" y="280" as="sourcePoint"/>
        <mxPoint x="580" y="280" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m4" value="compute SHA-256 hash" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="580" y="310" as="sourcePoint"/>
        <mxPoint x="580" y="335" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="630" y="310"/>
          <mxPoint x="630" y="335"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="BEGIN TRANSACTION" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="580" y="355" as="sourcePoint"/>
        <mxPoint x="740" y="355" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m6" value="DELETE old symbols + INSERT new" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="580" y="385" as="sourcePoint"/>
        <mxPoint x="740" y="385" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m7" value="UPDATE file row" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="580" y="415" as="sourcePoint"/>
        <mxPoint x="740" y="415" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m8" value="COMMIT" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="580" y="445" as="sourcePoint"/>
        <mxPoint x="740" y="445" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m9" value="OK" style="html=1;endSize=6;startSize=6;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="740" y="470" as="sourcePoint"/>
        <mxPoint x="580" y="470" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="note_perf" value="&lt;font style=&quot;font-size:9px&quot;&gt;Total: &amp;lt; 5s from&lt;br&gt;file save to index&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#fffde7;strokeColor=#f9a825;" vertex="1" parent="1">
      <mxGeometry x="690" y="480" width="120" height="40" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
