    <mxCell id="m8" value="Rows affected" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="670" y="400" as="sourcePoint"/>
        <mxPoint x="280" y="400" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m9" value="Log: &quot;Sync: {N} added, {M} updated, {P} deactivated&quot;" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
