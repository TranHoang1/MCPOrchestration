      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e5" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="n5" target="n6" parent="1">
