{
  "mcpServers": {
    "lowcode-devtools-local": {
      "command": "node",
      "args": [
        "c:/projects/nodejs/lowcode--devtools-mcp/build/src/bin/chrome-devtools-mcp.js"
      ],
      "env": {
        "KB_MCP_SERVER": "orchestrator",
        "KB_MCP_TOOL_INGEST": "kb_ingest",
        "KB_MCP_TOOL_SEARCH": "kb_search",
        "KB_MCP_TOOL_DELETE": "kb_delete",
        "LEARNING_DATA_DIR": ".learning"
      },
      "disabled": false,
      "autoApprove": [
        "list_pages",
        "navigate_page",
        "take_screenshot",
        "take_snapshot",
        "evaluate_script",
        "list_skills",
        "start_learning",
        "fill",
        "click",
        "stop_learning",
        "run_skill",
        "wait_for",
        "pause_learning",
        "resume_learning",
        "press_key",
        "list_console_messages",
        "get_console_message",
        "list_network_requests",
        "new_page"
      ]
    },
    "orchestrator": {
      "command": "npx",
      "args": [
        "mcp-orchestrator-bridge",
        "--url",
        "http://localhost:9180"
      ],
      "disabled": false,
      "autoApprove": [
        "find_tools",
        "execute_dynamic_tool",
        "toggle_tool",
        "reset_tools",
        "manage_auto_approve",
        "agent_log",
        "stream_write_file",
        "embed_images"
      ]
    }
  }
}