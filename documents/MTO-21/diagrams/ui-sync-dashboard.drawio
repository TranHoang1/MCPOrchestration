<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Page background -->
    <mxCell id="bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#16213e;shadow=0;" vertex="1" parent="1">
      <mxGeometry x="0" y="0" width="1200" height="820" as="geometry"/>
    </mxCell>
    <!-- Header section -->
    <mxCell id="header" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#0f3460;" vertex="1" parent="1">
      <mxGeometry x="40" y="20" width="1120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="title" value="&lt;font color=&quot;#eaeaea&quot; style=&quot;font-size:16px&quot;&gt;&lt;b&gt;🔄 Sync Dashboard&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="35" width="180" height="30" as="geometry"/>
    </mxCell>
    <!-- WS indicator -->
    <mxCell id="ws-dot" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=none;aspect=fixed;" vertex="1" parent="1">
      <mxGeometry x="560" y="42" width="12" height="12" as="geometry"/>
    </mxCell>
    <!-- Project input -->
    <mxCell id="project-input" value="&lt;font color=&quot;#8892b0&quot;&gt;MTO&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#8892b0;align=left;spacingLeft=10;" vertex="1" parent="1">
      <mxGeometry x="600" y="32" width="180" height="36" as="geometry"/>
    </mxCell>
    <!-- Start button -->
    <mxCell id="btn-start" value="&lt;font color=&quot;#ffffff&quot;&gt;▶ Start Sync&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=none;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="800" y="32" width="120" height="36" as="geometry"/>
    </mxCell>
    <!-- Stop button -->
    <mxCell id="btn-stop" value="&lt;font color=&quot;#ffffff&quot;&gt;⏹ Stop&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e94560;strokeColor=none;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="940" y="32" width="100" height="36" as="geometry"/>
    </mxCell>
    <!-- Progress section -->
    <mxCell id="progress-section" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#0f3460;" vertex="1" parent="1">
      <mxGeometry x="40" y="100" width="1120" height="80" as="geometry"/>
    </mxCell>
    <!-- Progress bar background -->
    <mxCell id="progress-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f3460;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="60" y="120" width="1080" height="24" as="geometry"/>
    </mxCell>
    <!-- Progress bar fill -->
    <mxCell id="progress-fill" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="60" y="120" width="720" height="24" as="geometry"/>
    </mxCell>
    <!-- Progress text -->
    <mxCell id="progress-text" value="&lt;font color=&quot;#8892b0&quot;&gt;45/67 issues (67.2%)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="60" y="150" width="200" height="20" as="geometry"/>
    </mxCell>
    <!-- Status Cards row -->
    <!-- Card 1: Status -->
    <mxCell id="card-status" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="40" y="200" width="350" height="100" as="geometry"/>
    </mxCell>
    <mxCell id="card-status-border" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4caf50;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="40" y="200" width="4" height="100" as="geometry"/>
    </mxCell>
    <mxCell id="card-status-label" value="&lt;font color=&quot;#8892b0&quot; style=&quot;font-size:11px&quot;&gt;Status&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="60" y="210" width="80" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="card-status-value" value="&lt;font color=&quot;#eaeaea&quot; style=&quot;font-size:20px&quot;&gt;&lt;b&gt;RUNNING&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="60" y="240" width="160" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="card-status-sub" value="&lt;font color=&quot;#8892b0&quot; style=&quot;font-size:10px&quot;&gt;MTO&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=bottom;" vertex="1" parent="1">
      <mxGeometry x="60" y="275" width="80" height="15" as="geometry"/>
