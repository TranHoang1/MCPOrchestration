<mxfile host="draw.io">
  <diagram name="TDD - SSO OAuth2/OIDC Flow" id="tdd-sso">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="650">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="SSO OAuth2/OIDC Login Flow" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="300" height="25" as="geometry"/>
        </mxCell>
        <!-- Participants -->
        <mxCell id="user" value="User Browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="100" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="orch" value="Orchestrator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="50" width="100" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="idp" value="Identity Provider" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="50" width="120" height="30" as="geometry"/>
        </mxCell>
        <!-- Steps as numbered flow -->
        <mxCell id="s1" value="1. GET /api/auth/sso/authorize" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#999;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="250" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="s2" value="2. Generate state + PKCE code_verifier" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="310" y="160" width="230" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="3. 302 Redirect to IdP (code_challenge)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#999;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="250" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="s4" value="4. User authenticates at IdP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="580" y="260" width="220" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="s5" value="5. 302 Redirect to callback?code=xxx&amp;state=yyy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#999;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="310" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="s6" value="6. Validate state (CSRF) + Exchange code for tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="310" y="360" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="s7" value="7. POST /token (code + code_verifier) → tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="580" y="410" width="250" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="s8" value="8. Extract claims → Find/Create user (JIT) → Issue JWT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="310" y="460" width="300" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="s9" value="9. 302 Redirect to portal + session token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="510" width="250" height="30" as="geometry"/>
        </mxCell>
        <!-- Arrows -->
        <mxCell id="a1" style="endArrow=block;endFill=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="s1" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" style="endArrow=block;endFill=1;html=1;exitX=0;exitY=1;entryX=0.5;entryY=0;" edge="1" source="s2" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3" style="endArrow=block;endFill=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="s3" target="s4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a4" style="endArrow=block;endFill=1;html=1;exitX=0;exitY=1;entryX=1;entryY=0;" edge="1" source="s4" target="s5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a5" style="endArrow=block;endFill=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="s5" target="s6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a6" style="endArrow=block;endFill=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="s6" target="s7" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a7" style="endArrow=open;dashed=1;html=1;exitX=0;exitY=1;entryX=1;entryY=0;" edge="1" source="s7" target="s8" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a8" style="endArrow=block;endFill=1;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="s8" target="s9" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
