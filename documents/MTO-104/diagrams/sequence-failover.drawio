      <mxGeometry x="80" y="60" width="120" height="620" as="geometry"/>
    </mxCell>
    <mxCell id="ll_reconn" value="Reconnection&#xa;Manager" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#fff3e0;strokeColor=#f57c00;size=40;" vertex="1" parent="1">
      <mxGeometry x="280" y="60" width="120" height="620" as="geometry"/>
