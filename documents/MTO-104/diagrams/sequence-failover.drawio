      <mxGeometry x="680" y="60" width="120" height="620" as="geometry"/>
    </mxCell>
    <mxCell id="m1" value="disconnect detected" style="html=1;endSize=6;startSize=6;strokeColor=#c62828;" edge="1" parent="1">
