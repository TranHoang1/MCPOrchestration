    <!-- Card 2: Synced Issues -->
    <mxCell id="card-synced" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="420" y="200" width="350" height="100" as="geometry"/>
