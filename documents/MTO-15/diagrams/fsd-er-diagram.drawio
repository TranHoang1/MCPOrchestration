<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="&lt;b&gt;ER Diagram — MTO-15: Jira Sync Tables&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="280" y="10" width="400" height="30" as="geometry"/>
    </mxCell>
    <!-- Table: jira_sync_state -->
    <mxCell id="sync_state_header" value="jira_sync_state" style="swimlane;startSize=24;fillColor=#e1f5fe;strokeColor=#0288d1;html=1;fontStyle=1;fontSize=12;align=center;" vertex="1" parent="1">
      <mxGeometry x="40" y="60" width="280" height="230" as="geometry"/>
    </mxCell>
    <mxCell id="sync_state_fields" value="&lt;div style='text-align:left;font-size:10px;line-height:1.6;'&gt;&#xa;🔑 project_key VARCHAR(50) PK&#xa;&lt;br&gt;last_sync_at TIMESTAMPTZ&#xa;&lt;br&gt;last_offset INTEGER DEFAULT 0&#xa;&lt;br&gt;total_issues INTEGER DEFAULT 0&#xa;&lt;br&gt;synced_issues INTEGER DEFAULT 0&#xa;&lt;br&gt;status VARCHAR(20) DEFAULT 'IDLE'&#xa;&lt;br&gt;error_message TEXT&#xa;&lt;br&gt;updated_at TIMESTAMPTZ DEFAULT NOW()&#xa;&lt;br&gt;&lt;br&gt;✓ CHECK: status IN (IDLE, RUNNING,&#xa;&lt;br&gt;  PAUSED, COMPLETED, FAILED)&#xa;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;overflow=fill;whiteSpace=wrap;fontSize=10;" vertex="1" parent="sync_state_header">
      <mxGeometry x="10" y="30" width="260" height="190" as="geometry"/>
    </mxCell>
    <!-- Table: jira_ticket_cache -->
    <mxCell id="ticket_cache_header" value="jira_ticket_cache" style="swimlane;startSize=24;fillColor=#e8f5e9;strokeColor=#388e3c;html=1;fontStyle=1;fontSize=12;align=center;" vertex="1" parent="1">
      <mxGeometry x="420" y="60" width="280" height="310" as="geometry"/>
    </mxCell>
    <mxCell id="ticket_cache_fields" value="&lt;div style='text-align:left;font-size:10px;line-height:1.6;'&gt;&#xa;🔑 ticket_key VARCHAR(50) PK&#xa;&lt;br&gt;project_key VARCHAR(50) NOT NULL&#xa;&lt;br&gt;summary TEXT NOT NULL&#xa;&lt;br&gt;issue_type VARCHAR(50) NOT NULL&#xa;&lt;br&gt;status VARCHAR(50) NOT NULL&#xa;&lt;br&gt;priority VARCHAR(20)&#xa;&lt;br&gt;parent_key VARCHAR(50)&#xa;&lt;br&gt;epic_key VARCHAR(50)&#xa;&lt;br&gt;labels JSONB&#xa;&lt;br&gt;updated_at_jira TIMESTAMPTZ NOT NULL&#xa;&lt;br&gt;synced_at TIMESTAMPTZ DEFAULT NOW()&#xa;&lt;br&gt;content_hash VARCHAR(64) NOT NULL&#xa;&lt;br&gt;kb_ingested BOOLEAN DEFAULT FALSE&#xa;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;overflow=fill;whiteSpace=wrap;fontSize=10;" vertex="1" parent="ticket_cache_header">
      <mxGeometry x="10" y="30" width="260" height="270" as="geometry"/>
    </mxCell>
    <!-- Table: jira_ticket_graph -->
    <mxCell id="ticket_graph_header" value="jira_ticket_graph" style="swimlane;startSize=24;fillColor=#fff3e0;strokeColor=#f57c00;html=1;fontStyle=1;fontSize=12;align=center;" vertex="1" parent="1">
      <mxGeometry x="420" y="440" width="280" height="160" as="geometry"/>
    </mxCell>
    <mxCell id="ticket_graph_fields" value="&lt;div style='text-align:left;font-size:10px;line-height:1.6;'&gt;&#xa;🔑 source_key VARCHAR(50) PK&#xa;&lt;br&gt;🔑 target_key VARCHAR(50) PK&#xa;&lt;br&gt;🔑 link_type VARCHAR(100) PK&#xa;&lt;br&gt;category VARCHAR(20) NOT NULL&#xa;&lt;br&gt;&lt;br&gt;✓ CHECK: category IN (INWARD,&#xa;&lt;br&gt;  OUTWARD, SUBTASK, EPIC)&#xa;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;overflow=fill;whiteSpace=wrap;fontSize=10;" vertex="1" parent="ticket_graph_header">
      <mxGeometry x="10" y="30" width="260" height="120" as="geometry"/>
    </mxCell>
    <!-- Table: jira_attachment_queue -->
    <mxCell id="attachment_queue_header" value="jira_attachment_queue" style="swimlane;startSize=24;fillColor=#f3e5f5;strokeColor=#7b1fa2;html=1;fontStyle=1;fontSize=12;align=center;" vertex="1" parent="1">
      <mxGeometry x="40" y="380" width="280" height="310" as="geometry"/>
    </mxCell>
    <mxCell id="attachment_queue_fields" value="&lt;div style='text-align:left;font-size:10px;line-height:1.6;'&gt;&#xa;🔑 id SERIAL PK&#xa;&lt;br&gt;ticket_key VARCHAR(50) NOT NULL&#xa;&lt;br&gt;attachment_id VARCHAR(50) NOT NULL&#xa;&lt;br&gt;filename VARCHAR(500) NOT NULL&#xa;&lt;br&gt;mime_type VARCHAR(100)&#xa;&lt;br&gt;size_bytes BIGINT&#xa;&lt;br&gt;download_url TEXT NOT NULL&#xa;&lt;br&gt;status VARCHAR(20) DEFAULT 'PENDING'&#xa;&lt;br&gt;retry_count INTEGER DEFAULT 0&#xa;&lt;br&gt;error_message TEXT&#xa;&lt;br&gt;created_at TIMESTAMPTZ DEFAULT NOW()&#xa;&lt;br&gt;processed_at TIMESTAMPTZ&#xa;&lt;br&gt;&lt;br&gt;⚡ UNIQUE(ticket_key, attachment_id)&#xa;&lt;br&gt;✓ CHECK: status IN (PENDING,&#xa;&lt;br&gt;  DOWNLOADING, PROCESSING, DONE, FAILED)&#xa;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;overflow=fill;whiteSpace=wrap;fontSize=10;" vertex="1" parent="attachment_queue_header">
      <mxGeometry x="10" y="30" width="260" height="270" as="geometry"/>
    </mxCell>
    <!-- Relationship: sync_state 1:N ticket_cache (project_key) -->
    <mxCell id="rel1" value="1:N&#xa;(project_key)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=ERmany;startArrow=ERmandOne;endSize=12;startSize=12;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.3;" edge="1" source="sync_state_header" target="ticket_cache_header" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Relationship: ticket_cache 1:N ticket_graph (source_key) -->
    <mxCell id="rel2" value="1:N&#xa;(source_key)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=ERmany;startArrow=ERmandOne;endSize=12;startSize=12;fontSize=10;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="ticket_cache_header" target="ticket_graph_header" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Relationship: ticket_cache 1:N attachment_queue (ticket_key) -->
    <mxCell id="rel3" value="1:N&#xa;(ticket_key)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=ERmany;startArrow=ERmandOne;endSize=12;startSize=12;fontSize=10;exitX=0;exitY=0.8;entryX=0.5;entryY=0;" edge="1" source="ticket_cache_header" target="attachment_queue_header" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Legend -->
    <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;🔑 = Primary Key&lt;br&gt;⚡ = Unique Constraint&lt;br&gt;✓ = Check Constraint&lt;br&gt;--- = Logical FK (not enforced)" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="760" y="60" width="180" height="100" as="geometry"/>
    </mxCell>
    <!-- Note: No FK enforcement -->
    <mxCell id="note1" value="&lt;i&gt;Note: FK constraints are NOT enforced&#xa;at DB level (deliberate design decision&#xa;to allow partial sync and concurrent&#xa;processing)&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=9;fontColor=#666666;" vertex="1" parent="1">
      <mxGeometry x="760" y="180" width="200" height="60" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
