    <mxCell id="card-synced-label" value="&lt;font color=&quot;#8892b0&quot; style=&quot;font-size:11px&quot;&gt;Synced Issues&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="440" y="210" width="100" height="20" as="geometry"/>
