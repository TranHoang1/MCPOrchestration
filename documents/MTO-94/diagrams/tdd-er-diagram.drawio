        <mxCell id="r2" value="1:N" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;html=1;exitX=1;exitY=0.8;entryX=0;entryY=0.4;fontSize=10;labelBackgroundColor=#FFF;" edge="1" source="u_b" target="bt_b" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="r3" value="1:N" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;fontSize=10;labelBackgroundColor=#FFF;" edge="1" source="ms_b" target="cs_b" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
