    </mxCell>
    <mxCell id="m5" value="retry activeUrl (attempt 2)" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="340" y="280" as="sourcePoint"/>
        <mxPoint x="740" y="280" as="targetPoint"/>
