<mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- Title -->
    <mxCell id="title" value="Tool Discovery &amp; Execution Flow" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
      <mxGeometry x="400" y="20" width="300" height="30" as="geometry" />
    </mxCell>

    <!-- Step 1: Agent asks -->
    <mxCell id="step1" value="&lt;b&gt;1. Agent Query&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;&lt;code&gt;find_tools({query: &quot;get issue details&quot;})&lt;/code&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=12;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="90" width="260" height="60" as="geometry" />
    </mxCell>

    <!-- Step 2: Embedding -->
    <mxCell id="step2" value="&lt;b&gt;2. Generate Embedding&lt;/b&gt;&lt;br&gt;Query → text-embedding-3-small → vector[768]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=12;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="200" width="260" height="60" as="geometry" />
    </mxCell>

    <!-- Step 3: Vector Search -->
    <mxCell id="step3" value="&lt;b&gt;3. Semantic Search&lt;/b&gt;&lt;br&gt;Cosine similarity in Qdrant/pgvector&lt;br&gt;threshold=0.4, top_k=5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=12;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="310" width="260" height="70" as="geometry" />
    </mxCell>

    <!-- Step 4: Results -->
    <mxCell id="step4" value="&lt;b&gt;4. Return Matched Tools&lt;/b&gt;&lt;br&gt;[{name, description, server, score}]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=12;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="430" width="260" height="60" as="geometry" />
    </mxCell>

    <!-- Step 5: Agent picks tool -->
    <mxCell id="step5" value="&lt;b&gt;5. Agent Selects Tool&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;&lt;code&gt;execute_dynamic_tool({tool_name: &quot;jira_get_issue&quot;, arguments: {...}})&lt;/code&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=12;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="540" width="320" height="60" as="geometry" />
    </mxCell>

    <!-- Step 6: Route to upstream -->
    <mxCell id="step6" value="&lt;b&gt;6. Route to Upstream&lt;/b&gt;&lt;br&gt;Orchestrator finds server owning tool&lt;br&gt;Forwards call via stdio/HTTP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=12;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="500" y="540" width="260" height="70" as="geometry" />
    </mxCell>

    <!-- Step 7: Upstream executes -->
    <mxCell id="step7" value="&lt;b&gt;7. Upstream Executes&lt;/b&gt;&lt;br&gt;Jira MCP Server processes request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=12;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="840" y="540" width="240" height="60" as="geometry" />
    </mxCell>

    <!-- Step 8: Response -->
    <mxCell id="step8" value="&lt;b&gt;8. Return Result&lt;/b&gt;&lt;br&gt;Response flows back: Upstream → Orchestrator → Bridge → Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=12;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="840" y="430" width="260" height="60" as="geometry" />
    </mxCell>

    <!-- Arrows -->
    <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;" edge="1" parent="1" source="step1" target="step2">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;" edge="1" parent="1" source="step2" target="step3">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;" edge="1" parent="1" source="step3" target="step4">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;" edge="1" parent="1" source="step4" target="step5">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#333333;" edge="1" parent="1" source="step5" target="step6">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#333333;" edge="1" parent="1" source="step6" target="step7">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#d6b656;dashed=1;" edge="1" parent="1" source="step7" target="step8">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Fallback path -->
    <mxCell id="fallback" value="&lt;b&gt;Fallback: Keyword Search&lt;/b&gt;&lt;br&gt;If no semantic match (score &lt; threshold)&lt;br&gt;→ TF-IDF keyword search" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=12;fontSize=10;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="500" y="310" width="240" height="70" as="geometry" />
    </mxCell>
    <mxCell id="af" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#d6b656;dashed=1;" edge="1" parent="1" source="step3" target="fallback">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="af-label" value="no match" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#d6b656;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="370" y="330" width="60" height="20" as="geometry" />
    </mxCell>

    <!-- Right side: Indexing -->
    <mxCell id="index-title" value="Tool Indexing (on server connect)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="800" y="90" width="230" height="20" as="geometry" />
    </mxCell>
    <mxCell id="idx1" value="Upstream connects →&lt;br&gt;List all tools" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=10;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="820" y="120" width="160" height="45" as="geometry" />
    </mxCell>
    <mxCell id="idx2" value="Generate embedding&lt;br&gt;for each tool description" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=10;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="820" y="185" width="160" height="45" as="geometry" />
    </mxCell>
    <mxCell id="idx3" value="Store vectors in&lt;br&gt;Qdrant / pgvector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=10;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="820" y="250" width="160" height="45" as="geometry" />
    </mxCell>
    <mxCell id="ai1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#9673a6;" edge="1" parent="1" source="idx1" target="idx2">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="ai2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#9673a6;" edge="1" parent="1" source="idx2" target="idx3">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
  </root>
</mxGraphModel>