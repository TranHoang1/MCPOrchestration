<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Page background (dark) -->
    <mxCell id="bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#30363d;" vertex="1" parent="1">
      <mxGeometry x="0" y="0" width="1200" height="800" as="geometry"/>
    </mxCell>
    <!-- Controls bar (top-left, fixed) -->
    <mxCell id="controls" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;" vertex="1" parent="1">
      <mxGeometry x="16" y="16" width="700" height="40" as="geometry"/>
    </mxCell>
    <!-- Project input -->
    <mxCell id="project-input" value="&lt;font color=&quot;#c9d1d9&quot;&gt;MTO&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="24" y="22" width="80" height="28" as="geometry"/>
    </mxCell>
    <!-- View mode select -->
    <mxCell id="view-select" value="&lt;font color=&quot;#c9d1d9&quot;&gt;Hierarchy ▾&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="114" y="22" width="130" height="28" as="geometry"/>
