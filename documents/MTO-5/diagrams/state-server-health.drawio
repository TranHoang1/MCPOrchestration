      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_connected_end" value="Server removed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="connected" target="end_state" parent="1">
