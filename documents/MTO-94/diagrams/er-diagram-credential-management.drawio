<mxfile host="draw.io">
  <diagram name="ER Diagram - Credential Management" id="er1">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="750">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- users table -->
        <mxCell id="t1_header" value="users (existing + modified)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1565C0;fontColor=#FFFFFF;fontSize=11;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="t1_body" value="&lt;div style='text-align:left;font-size:10px;line-height:1.5;padding:4px'&gt;&lt;b&gt;PK&lt;/b&gt; id : TEXT&lt;br&gt;email : TEXT (UNIQUE)&lt;br&gt;name : TEXT&lt;br&gt;role : TEXT&lt;br&gt;active : BOOLEAN &lt;font color='#C62828'&gt;[NEW]&lt;/font&gt;&lt;br&gt;password_hash : TEXT &lt;font color='#C62828'&gt;[NEW]&lt;/font&gt;&lt;br&gt;auth_mode : TEXT &lt;font color='#C62828'&gt;[NEW]&lt;/font&gt;&lt;br&gt;failed_login_attempts : INT &lt;font color='#C62828'&gt;[NEW]&lt;/font&gt;&lt;br&gt;locked_until : TEXT &lt;font color='#C62828'&gt;[NEW]&lt;/font&gt;&lt;br&gt;created_at : TEXT &lt;font color='#C62828'&gt;[NEW]&lt;/font&gt;&lt;br&gt;updated_at : TEXT &lt;font color='#C62828'&gt;[NEW]&lt;/font&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;verticalAlign=top;align=left;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="280" height="190" as="geometry"/>
        </mxCell>

        <!-- credential_schemas table -->
        <mxCell id="t2_header" value="credential_schemas [NEW]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2E7D32;fontColor=#FFFFFF;fontSize=11;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="400" y="40" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="t2_body" value="&lt;div style='text-align:left;font-size:10px;line-height:1.5;padding:4px'&gt;&lt;b&gt;PK&lt;/b&gt; id : TEXT&lt;br&gt;&lt;b&gt;FK&lt;/b&gt; server_name : TEXT&lt;br&gt;field_key : TEXT&lt;br&gt;field_label : TEXT&lt;br&gt;field_type : TEXT (url|email|secret|text|number)&lt;br&gt;field_required : BOOLEAN&lt;br&gt;field_description : TEXT&lt;br&gt;field_placeholder : TEXT&lt;br&gt;display_order : INT&lt;br&gt;created_at : TEXT&lt;br&gt;updated_at : TEXT&lt;br&gt;&lt;br&gt;&lt;i&gt;UNIQUE(server_name, field_key)&lt;/i&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;verticalAlign=top;align=left;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="400" y="70" width="280" height="210" as="geometry"/>
        </mxCell>

        <!-- user_credentials table -->
        <mxCell id="t3_header" value="user_credentials [NEW]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E65100;fontColor=#FFFFFF;fontSize=11;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="t3_body" value="&lt;div style='text-align:left;font-size:10px;line-height:1.5;padding:4px'&gt;&lt;b&gt;PK&lt;/b&gt; id : TEXT&lt;br&gt;&lt;b&gt;FK&lt;/b&gt; user_id : TEXT&lt;br&gt;&lt;b&gt;FK&lt;/b&gt; server_name : TEXT&lt;br&gt;credentials_encrypted : TEXT (AES-256-GCM)&lt;br&gt;created_at : TEXT&lt;br&gt;updated_at : TEXT&lt;br&gt;&lt;br&gt;&lt;i&gt;UNIQUE(user_id, server_name)&lt;/i&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;verticalAlign=top;align=left;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="350" width="280" height="140" as="geometry"/>
        </mxCell>

        <!-- bridge_tokens table -->
        <mxCell id="t4_header" value="bridge_tokens [NEW]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#6A1B9A;fontColor=#FFFFFF;fontSize=11;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="400" y="320" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="t4_body" value="&lt;div style='text-align:left;font-size:10px;line-height:1.5;padding:4px'&gt;&lt;b&gt;PK&lt;/b&gt; id : TEXT&lt;br&gt;&lt;b&gt;FK&lt;/b&gt; user_id : TEXT&lt;br&gt;token_hash : TEXT (SHA-256)&lt;br&gt;expires_at : TEXT (1-365 days)&lt;br&gt;revoked : BOOLEAN&lt;br&gt;created_at : TEXT&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;verticalAlign=top;align=left;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="400" y="350" width="280" height="120" as="geometry"/>
        </mxCell>

        <!-- mcp_servers table -->
        <mxCell id="t5_header" value="mcp_servers (existing)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#37474F;fontColor=#FFFFFF;fontSize=11;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="780" y="40" width="250" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="t5_body" value="&lt;div style='text-align:left;font-size:10px;line-height:1.5;padding:4px'&gt;&lt;b&gt;PK&lt;/b&gt; id : TEXT&lt;br&gt;name : TEXT (UNIQUE)&lt;br&gt;command : TEXT&lt;br&gt;args : TEXT&lt;br&gt;env : TEXT (JSON)&lt;br&gt;transport : TEXT&lt;br&gt;disabled : BOOLEAN&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#37474F;verticalAlign=top;align=left;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="780" y="70" width="250" height="130" as="geometry"/>
        </mxCell>

        <!-- sso_config table -->
        <mxCell id="t6_header" value="sso_config [NEW]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#00695C;fontColor=#FFFFFF;fontSize=11;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="780" y="320" width="250" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="t6_body" value="&lt;div style='text-align:left;font-size:10px;line-height:1.5;padding:4px'&gt;&lt;b&gt;PK&lt;/b&gt; id : TEXT (singleton)&lt;br&gt;sso_enabled : BOOLEAN&lt;br&gt;issuer_url : TEXT&lt;br&gt;client_id : TEXT&lt;br&gt;client_secret_encrypted : TEXT&lt;br&gt;scopes : TEXT&lt;br&gt;callback_url : TEXT&lt;br&gt;claims_mapping : TEXT (JSON)&lt;br&gt;default_role : TEXT&lt;br&gt;jit_provisioning : BOOLEAN&lt;br&gt;updated_at : TEXT&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;verticalAlign=top;align=left;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="780" y="350" width="250" height="190" as="geometry"/>
        </mxCell>

        <!-- Relationships -->
        <!-- users 1:N user_credentials -->
        <mxCell id="r1" value="1 : N" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;html=1;rounded=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" source="t1_body" target="t3_header" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- users 1:N bridge_tokens -->
        <mxCell id="r2" value="1 : N" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;html=1;rounded=1;exitX=1;exitY=0.8;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" source="t1_body" target="t4_body" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- mcp_servers 1:N credential_schemas -->
        <mxCell id="r3" value="1 : N" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;html=1;rounded=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" source="t5_body" target="t2_body" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- mcp_servers 1:N user_credentials (via server_name) -->
        <mxCell id="r4" value="1 : N" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;html=1;rounded=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.3;entryDx=0;entryDy=0;fontSize=10;labelBackgroundColor=#FFFFFF;dashed=1;" edge="1" source="t5_body" target="t3_body" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="750" y="200"/>
              <mxPoint x="750" y="392"/>
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
