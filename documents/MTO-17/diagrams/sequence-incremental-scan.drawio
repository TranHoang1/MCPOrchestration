        <mxPoint x="640" y="250" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="SearchResult(total=5, issues[0..4])" style="html=1;endSize=6;startSize=6;fontSize=10;dashed=1;" edge="1" parent="1">
