<mxfile host="draw.io">
  <diagram name="TDD - Process Pool State Machine" id="tdd-sm">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="550">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="Process State Machine" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="200" height="25" as="geometry"/>
        </mxCell>
        <!-- States -->
        <mxCell id="start" value="" style="ellipse;fillColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="20" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="starting" value="STARTING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#F57C00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="235" width="120" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="idle" value="IDLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="235" width="120" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="busy" value="BUSY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="80" width="120" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="stopping" value="STOPPING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#607D8B;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="420" width="120" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="crashed" value="CRASHED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="150" width="120" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="end" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="650" y="440" width="20" height="20" as="geometry"/>
        </mxCell>
        <!-- Transitions -->
        <mxCell id="t1" value="spawn()" style="endArrow=block;endFill=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=9;" edge="1" source="start" target="starting" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="init success" style="endArrow=block;endFill=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=9;" edge="1" source="starting" target="idle" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t3" value="acquire()" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;fontSize=9;" edge="1" source="idle" target="busy" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t4" value="release()" style="endArrow=block;endFill=1;html=1;exitX=0;exitY=1;entryX=0;entryY=0;fontSize=9;" edge="1" source="busy" target="idle" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="300" y="160"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="t5" value="idle > timeout" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=9;" edge="1" source="idle" target="stopping" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t6" value="terminated" style="endArrow=block;endFill=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=9;" edge="1" source="stopping" target="end" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t7" value="process dies" style="endArrow=block;endFill=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=9;strokeColor=#C62828;" edge="1" source="busy" target="crashed" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t8" value="spawn failure" style="endArrow=block;endFill=1;html=1;exitX=1;exitY=0;entryX=0;entryY=1;fontSize=9;strokeColor=#C62828;" edge="1" source="starting" target="crashed" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t9" value="auto-restart" style="endArrow=block;endFill=1;html=1;exitX=0;exitY=1;entryX=1;entryY=0;fontSize=9;dashed=1;" edge="1" source="crashed" target="starting" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="500" y="300"/>
              <mxPoint x="240" y="300"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Notes -->
        <mxCell id="note1" value="Scale UP when:&#xa;• avg_response &gt; threshold&#xa;• pool.size &lt; max" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#FBC02D;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="560" y="50" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="note2" value="Scale DOWN when:&#xa;• idle_time &gt; timeout&#xa;• pool.size &gt; 1" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#FBC02D;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="560" y="350" width="180" height="60" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
