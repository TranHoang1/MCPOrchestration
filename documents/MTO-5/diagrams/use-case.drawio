    <mxCell id="sys_boundary" value="MCP Orchestration Server" style="swimlane;startSize=30;fillColor=#e1f5fe;strokeColor=#0288d1;html=1;fontSize=13;fontStyle=1;rounded=1;" vertex="1" parent="1">
