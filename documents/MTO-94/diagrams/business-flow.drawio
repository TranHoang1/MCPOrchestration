<mxfile host="draw.io">
  <diagram name="Business Flow - Per-User Credentials" id="bf1">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="780">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Business Flow: Per-User Credential Tool Execution" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 1: SETUP (left column) ===== -->
        <mxCell id="ph1_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;strokeWidth=2;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="320" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="ph1_title" value="SETUP (One-time)" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="100" y="70" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="s1" value="1. Admin creates User account" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;spacingLeft=5;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="110" width="260" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="s2" value="2. Admin defines Credential Schema&#xa;    per upstream server (dynamic fields)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;spacingLeft=5;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="170" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="3. User logs in&#xa;    (Local password OR SSO)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;fontSize=11;spacingLeft=5;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="250" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s4" value="4. User fills personal credentials&#xa;    for each upstream server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;fontSize=11;spacingLeft=5;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="330" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s5" value="5. Credentials encrypted (AES-256-GCM)&#xa;    and stored in database" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;fontSize=11;spacingLeft=5;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="410" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s6" value="6. User generates Bridge Token&#xa;    (JWT, configurable up to 365 days)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;fontSize=11;spacingLeft=5;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="490" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s7" value="7. User configures MCP Bridge&#xa;    with --token &lt;jwt&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;fontSize=11;spacingLeft=5;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="570" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s_ready" value="✅ Ready for tool execution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="660" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- Setup arrows (simple vertical) -->
        <mxCell id="sa1" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="s1" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="sa2" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="s2" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="sa3" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="s3" target="s4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="sa4" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="s4" target="s5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="sa5" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="s5" target="s6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="sa6" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="s6" target="s7" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="sa7" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#666666;" edge="1" source="s7" target="s_ready" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== PHASE 2: RUNTIME (right column) ===== -->
        <mxCell id="ph2_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FFB74D;strokeWidth=2;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="420" y="60" width="640" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="ph2_title" value="RUNTIME (Every tool invocation)" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="560" y="70" width="300" height="25" as="geometry"/>
        </mxCell>

        <!-- Runtime nodes - left sub-column (actors) -->
        <mxCell id="r1" value="IDE invokes tool" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="120" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="r2" value="Bridge sends POST /mcp&#xa;with Authorization: Bearer &lt;jwt&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="200" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r3" value="Orchestrator validates JWT&#xa;→ identifies user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#F57C00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="300" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r4" value="Credential Resolver:&#xa;• Fetch user's encrypted credentials&#xa;• Decrypt (AES-256-GCM)&#xa;• Replace {placeholders} in server config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="460" y="400" width="250" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="r5" value="Process Pool Manager:&#xa;• Compute pool key = SHA-256(server + creds)&#xa;• Acquire process (warm &lt;100ms / cold &lt;5s)&#xa;• Same creds → share process" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="460" y="530" width="270" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="r6" value="Execute tool on Upstream Server&#xa;with user's own credentials" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="660" width="230" height="50" as="geometry"/>
        </mxCell>

        <!-- Return arrow (right side) -->
        <mxCell id="r7" value="Result returned&#xa;to IDE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="120" width="140" height="40" as="geometry"/>
        </mxCell>

        <!-- Runtime arrows (simple vertical) -->
        <mxCell id="ra1" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=1;" edge="1" source="r1" target="r2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ra2" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=1;" edge="1" source="r2" target="r3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ra3" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=1;" edge="1" source="r3" target="r4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ra4" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=1;" edge="1" source="r4" target="r5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ra5" style="endArrow=block;endFill=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#333333;strokeWidth=1;" edge="1" source="r5" target="r6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Return path (right side, going up) -->
        <mxCell id="ra6" style="endArrow=block;endFill=1;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#1976D2;strokeWidth=2;dashed=1;" edge="1" source="r6" target="r7" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="890" y="685"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Cross-phase connector: Ready → Runtime -->
        <mxCell id="cross1" style="endArrow=block;endFill=1;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#2E7D32;strokeWidth=2;dashed=1;" edge="1" source="s_ready" target="r1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="390" y="680"/>
              <mxPoint x="390" y="140"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Legend -->
        <mxCell id="leg_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#E0E0E0;" vertex="1" parent="1">
          <mxGeometry x="770" y="500" width="260" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="leg_title" value="Legend" style="text;html=1;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="505" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;" vertex="1" parent="1">
          <mxGeometry x="785" y="530" width="20" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="leg1t" value="Admin action" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="815" y="528" width="100" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;" vertex="1" parent="1">
          <mxGeometry x="785" y="555" width="20" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="leg2t" value="User action" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="815" y="553" width="100" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#F57C00;" vertex="1" parent="1">
          <mxGeometry x="785" y="580" width="20" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="leg3t" value="Orchestrator (auth)" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="815" y="578" width="120" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="785" y="605" width="20" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="leg4t" value="Credential resolution" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="815" y="603" width="130" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg5" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;" vertex="1" parent="1">
          <mxGeometry x="785" y="630" width="20" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="leg5t" value="Process pool management" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="815" y="628" width="150" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
