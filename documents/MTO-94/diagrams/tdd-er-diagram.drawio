        <mxCell id="bt_h" value="bridge_tokens [NEW]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#6A1B9A;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="290" width="240" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="bt_b" value="&lt;div style='text-align:left;font-size:10px;line-height:1.4;padding:3px'&gt;&lt;b&gt;PK&lt;/b&gt; id : TEXT&lt;br&gt;&lt;b&gt;FK&lt;/b&gt; user_id : TEXT&lt;br&gt;token_hash : TEXT&lt;br&gt;expires_at : TEXT&lt;br&gt;revoked : BOOLEAN&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;verticalAlign=top;align=left;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="380" y="315" width="240" height="95" as="geometry"/>
        </mxCell>

        <!-- mcp_servers -->
        <mxCell id="ms_h" value="mcp_servers (existing)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#37474F;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="40" width="220" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="ms_b" value="&lt;div style='text-align:left;font-size:10px;line-height:1.4;padding:3px'&gt;&lt;b&gt;PK&lt;/b&gt; id : TEXT&lt;br&gt;name : TEXT (UK)&lt;br&gt;command : TEXT&lt;br&gt;args : TEXT&lt;br&gt;transport : TEXT&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#37474F;verticalAlign=top;align=left;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="730" y="65" width="220" height="95" as="geometry"/>
        </mxCell>

        <!-- sso_config -->
        <mxCell id="sc_h" value="sso_config [NEW]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#00695C;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="290" width="220" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="sc_b" value="&lt;div style='text-align:left;font-size:10px;line-height:1.4;padding:3px'&gt;&lt;b&gt;PK&lt;/b&gt; id : TEXT (singleton)&lt;br&gt;sso_enabled : BOOLEAN&lt;br&gt;issuer_url : TEXT&lt;br&gt;client_id : TEXT&lt;br&gt;client_secret_encrypted : TEXT&lt;br&gt;claims_mapping : TEXT (JSON)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;verticalAlign=top;align=left;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="730" y="315" width="220" height="115" as="geometry"/>
        </mxCell>

        <!-- Relationships -->
        <mxCell id="r1" value="1:N" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;labelBackgroundColor=#FFF;" edge="1" source="u_b" target="uc_h" parent="1">
          <mxGeometry relative="1" as="geometry"/>
