        <mxPoint x="470" y="150" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m3" value="SyncState(COMPLETED, lastSync=T1)" style="html=1;endSize=6;startSize=6;fontSize=10;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="470" y="180" as="sourcePoint"/>
        <mxPoint x="290" y="180" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="note1" value="JQL: project=X AND updated &gt; T1-1min" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#d6b656;fontSize=10;size=14;" vertex="1" parent="1">
      <mxGeometry x="140" y="195" width="200" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="m4" value="searchIssues(incrementalJql)" style="html=1;endSize=6;startSize=6;fontSize=10;" edge="1" parent="1">
