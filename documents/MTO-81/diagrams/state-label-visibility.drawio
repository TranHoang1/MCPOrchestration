<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="&lt;b&gt;State Diagram — Label Visibility&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="200" y="10" width="300" height="30" as="geometry"/>
    </mxCell>
    <!-- States -->
    <mxCell id="hidden" value="&lt;b&gt;HIDDEN&lt;/b&gt;&#xa;opacity = 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="60" y="160" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="fading_in" value="&lt;b&gt;FADING_IN&lt;/b&gt;&#xa;opacity → 1.0&#xa;(300ms lerp)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="340" y="60" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="visible" value="&lt;b&gt;VISIBLE&lt;/b&gt;&#xa;opacity = 1.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="600" y="160" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="fading_out" value="&lt;b&gt;FADING_OUT&lt;/b&gt;&#xa;opacity → 0&#xa;(300ms lerp)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="340" y="260" width="160" height="70" as="geometry"/>
    </mxCell>
    <!-- Initial state -->
    <mxCell id="init" value="" style="ellipse;fillColor=#388e3c;strokeColor=#388e3c;" vertex="1" parent="1">
      <mxGeometry x="120" y="70" width="30" height="30" as="geometry"/>
    </mxCell>
    <!-- Transitions -->
    <mxCell id="e0" value="created" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="init" target="hidden" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e1" value="apparentSize ≥&#xa;showThreshold" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="hidden" target="fading_in" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e2" value="opacity = 1.0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="fading_in" target="visible" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e3" value="apparentSize &lt;&#xa;hideThreshold" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="visible" target="fading_out" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e4" value="opacity = 0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="fading_out" target="hidden" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Cancel transitions -->
    <mxCell id="e5" value="apparentSize &lt;&#xa;hideThreshold&#xa;(cancel)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;dashed=1;" edge="1" source="fading_in" target="fading_out" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e6" value="apparentSize ≥&#xa;showThreshold&#xa;(cancel)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;dashed=1;" edge="1" source="fading_out" target="fading_in" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Hysteresis note -->
    <mxCell id="note" value="&lt;i&gt;Hysteresis Zone:&#xa;hideThreshold &lt; apparentSize &lt; showThreshold&#xa;→ No state change (prevents flickering)&lt;/i&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="250" y="370" width="300" height="60" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
