    <mxCell id="m9" value="ScanResult(5, 5, INCREMENTAL, COMPLETED)" style="html=1;endSize=6;startSize=6;fontSize=10;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
