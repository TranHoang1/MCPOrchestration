    <mxCell id="m3" value="SyncState(IDLE)" style="html=1;endSize=6;startSize=6;dashed=1;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="520" y="165" as="sourcePoint"/>
        <mxPoint x="320" y="165" as="targetPoint"/>
