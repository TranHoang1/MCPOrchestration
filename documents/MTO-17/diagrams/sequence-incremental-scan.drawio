        <mxPoint x="640" y="280" as="sourcePoint"/>
        <mxPoint x="290" y="280" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m6" value="markRunning(projectKey, 5)" style="html=1;endSize=6;startSize=6;fontSize=10;" edge="1" parent="1">
