<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;State Diagram — Database Lifecycle&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="200" y="10" width="300" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="start" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="60" y="110" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="not_exists" value="NOT_EXISTS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="160" y="100" width="140" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="initializing" value="INITIALIZING&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Creating DB + tables&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="380" y="100" width="160" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="migrating" value="MIGRATING&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Running migrations&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="620" y="100" width="150" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="ready" value="READY&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Accepting queries&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="380" y="250" width="160" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="error" value="ERROR&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Disabled&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="160" y="250" width="140" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="e_start" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="start" target="not_exists" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_ne_init" value="bridge startup" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="not_exists" target="initializing" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_init_mig" value="schema outdated" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="initializing" target="migrating" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_init_ready" value="schema current" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="initializing" target="ready" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_mig_ready" value="migrations done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="migrating" target="ready" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_init_err" value="creation failed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;strokeColor=#c62828;" edge="1" source="initializing" target="error" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_mig_err" value="migration failed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;strokeColor=#c62828;" edge="1" source="migrating" target="error" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_ready_ne" value="DB deleted (reset)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;dashed=1;" edge="1" source="ready" target="not_exists" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="460" y="370"/>
          <mxPoint x="230" y="370"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e_err_ne" value="retry (recreate)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;dashed=1;" edge="1" source="error" target="not_exists" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="100" y="275"/>
          <mxPoint x="100" y="125"/>
        </Array>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
