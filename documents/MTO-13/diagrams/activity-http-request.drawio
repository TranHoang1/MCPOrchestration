      <mxGeometry x="320" y="940" width="140" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="respond_json" value="Return application/json Response" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="150" y="1060" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="respond_sse" value="Stream text/event-stream&lt;br&gt;(Assign Event IDs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="470" y="1060" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="update_activity" value="Update Session last_activity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
