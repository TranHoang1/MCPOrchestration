    <mxCell id="inc3" value="&lt;i&gt;&amp;lt;&amp;lt;extend&amp;gt;&amp;gt;&lt;/i&gt;" style="html=1;dashed=1;endArrow=open;endSize=8;" edge="1" source="uc7" target="uc8" parent="1">
