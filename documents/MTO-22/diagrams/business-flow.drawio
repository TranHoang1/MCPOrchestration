<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="lane1" value="User / Project Manager" style="swimlane;horizontal=0;startSize=110;fillColor=#f5f5f5;html=1;" vertex="1" parent="1">
      <mxGeometry x="0" y="0" width="1620" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="n1" value="Navigate to&#xa;Graph Viewer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;" vertex="1" parent="lane1">
      <mxGeometry x="120" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="n2" value="Select Project" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;" vertex="1" parent="lane1">
      <mxGeometry x="300" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="n5" value="Interact with&#xa;3D Graph" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;" vertex="1" parent="lane1">
      <mxGeometry x="840" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
