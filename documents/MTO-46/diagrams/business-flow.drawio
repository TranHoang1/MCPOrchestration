    <mxCell id="n10" value="Receive Ping&#xa;Respond" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;" vertex="1" parent="lane3">
      <mxGeometry x="660" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
