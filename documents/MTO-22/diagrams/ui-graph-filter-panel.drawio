<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Page background (dark) -->
    <mxCell id="bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#30363d;" vertex="1" parent="1">
      <mxGeometry x="0" y="0" width="1200" height="500" as="geometry"/>
    </mxCell>
    <!-- Controls bar -->
    <mxCell id="controls" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;" vertex="1" parent="1">
      <mxGeometry x="16" y="16" width="700" height="40" as="geometry"/>
    </mxCell>
    <!-- Project input -->
    <mxCell id="project-input" value="&lt;font color=&quot;#c9d1d9&quot;&gt;MTO&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="24" y="22" width="80" height="28" as="geometry"/>
    </mxCell>
    <!-- View mode select -->
    <mxCell id="view-select" value="&lt;font color=&quot;#c9d1d9&quot;&gt;Hierarchy ▾&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="114" y="22" width="130" height="28" as="geometry"/>
    </mxCell>
    <!-- Search input -->
    <mxCell id="search-input" value="&lt;font color=&quot;#8b949e&quot;&gt;Search...&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="254" y="22" width="140" height="28" as="geometry"/>
    </mxCell>
    <!-- Filter toggle -->
    <mxCell id="filter-btn" value="&lt;font color=&quot;#58a6ff&quot;&gt;Filters ▾&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#58a6ff;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="404" y="22" width="80" height="28" as="geometry"/>
    </mxCell>
    <!-- Filter panel (expanded) -->
    <mxCell id="filter-panel" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#30363d;" vertex="1" parent="1">
      <mxGeometry x="16" y="64" width="700" height="120" as="geometry"/>
    </mxCell>
    <!-- Filter: Type -->
    <mxCell id="filter-type-label" value="&lt;font color=&quot;#8b949e&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Type:&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="28" y="72" width="40" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="chk-epic" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:10px&quot;&gt;☑ Epic&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="72" y="72" width="60" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="chk-story" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:10px&quot;&gt;☑ Story&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="136" y="72" width="60" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="chk-task" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:10px&quot;&gt;☑ Task&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="200" y="72" width="60" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="chk-bug" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:10px&quot;&gt;☑ Bug&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="264" y="72" width="60" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="chk-subtask" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:10px&quot;&gt;☐ Sub-task&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="328" y="72" width="80" height="20" as="geometry"/>
    </mxCell>
    <!-- Filter: Status -->
    <mxCell id="filter-status-label" value="&lt;font color=&quot;#8b949e&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Status:&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="28" y="100" width="50" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="chk-todo" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:10px&quot;&gt;☑ To Do&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="82" y="100" width="60" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="chk-inprog" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:10px&quot;&gt;☑ In Progress&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="146" y="100" width="90" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="chk-done" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:10px&quot;&gt;☑ Done&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="240" y="100" width="60" height="20" as="geometry"/>
    </mxCell>
    <!-- Filter: Assignee -->
    <mxCell id="filter-assignee-label" value="&lt;font color=&quot;#8b949e&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Assignee:&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="28" y="128" width="60" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="assignee-select" value="&lt;font color=&quot;#c9d1d9&quot; style=&quot;font-size:10px&quot;&gt;All ▾&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#30363d;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="92" y="128" width="100" height="22" as="geometry"/>
    </mxCell>
    <!-- Apply / Reset buttons -->
    <mxCell id="btn-apply" value="&lt;font color=&quot;#ffffff&quot;&gt;Apply&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#58a6ff;strokeColor=none;fontSize=10;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="560" y="130" width="60" height="24" as="geometry"/>
    </mxCell>
    <mxCell id="btn-reset" value="&lt;font color=&quot;#c9d1d9&quot;&gt;Reset&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#30363d;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="630" y="130" width="60" height="24" as="geometry"/>
    </mxCell>
    <!-- Graph area placeholder -->
    <mxCell id="graph-placeholder" value="&lt;font color=&quot;#8b949e&quot; style=&quot;font-size:14px&quot;&gt;3D Force Graph (filtered view)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="300" y="280" width="300" height="40" as="geometry"/>
    </mxCell>
    <!-- Annotation -->
    <mxCell id="ann-filter" value="&lt;font color=&quot;#58a6ff&quot; style=&quot;font-size:9px&quot;&gt;Filter panel expands&lt;br&gt;below controls on click&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="800" y="80" width="140" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="ann-filter-edge" style="html=1;dashed=1;strokeColor=#58a6ff;endArrow=classic;endSize=4;" edge="1" source="ann-filter" target="filter-panel" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>