    <mxCell id="hcm_class" value="&lt;b&gt;HealthCheckManager&lt;/b&gt;&#xa;&#xa;- config: HealthCheckConfig&#xa;- httpClient: HttpStreamableClient&#xa;- reconnectionManager: ReconnectionManager&#xa;- state: AtomicReference&lt;BridgeState&gt;&#xa;- consecutiveFailures: AtomicInteger&#xa;- pingId: AtomicInteger&#xa;- healthCheckJob: Job?&#xa;&#xa;+ start(): Unit&#xa;+ stop(): Unit&#xa;- sendPing(): Boolean&#xa;- onPingSuccess(): Unit&#xa;- onPingFailure(): Unit&#xa;- healthCheckLoop(): Unit" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
      <mxGeometry x="40" y="60" width="260" height="280" as="geometry"/>
