    <mxCell id="mcp_tools_col" value="&lt;b&gt;Collection: mcp_tools&lt;/b&gt;&lt;hr&gt;&lt;div style='text-align:left;padding:4px;font-size:10px;'&gt;&lt;b&gt;Vector Config:&lt;/b&gt;&lt;br&gt;  size: 768&lt;br&gt;  distance: Cosine&lt;br&gt;  index: HNSW (m=16, ef=128)&lt;br&gt;&lt;br&gt;&lt;b&gt;Point Schema:&lt;/b&gt;&lt;br&gt;  PK id : String (server::tool)&lt;br&gt;  vector : Float[768]&lt;br&gt;&lt;br&gt;&lt;b&gt;Payload Fields:&lt;/b&gt;&lt;br&gt;  name : String [keyword idx]&lt;br&gt;  description : String [text idx]&lt;br&gt;  input_schema : JSON&lt;br&gt;  server_name : String [keyword idx]&lt;br&gt;  indexed_at : String (ISO-8601)&lt;/div&gt;" style="shape=table;startSize=28;container=0;collapsible=0;childLayout=tableLayout;fixedRows=0;rowLines=0;fontStyle=1;align=center;resizeLast=0;html=1;whiteSpace=wrap;fillColor=#e1bee7;strokeColor=#7b1fa2;fontSize=11;" vertex="1" parent="qdrant_grp">
